FROM python:3.11-slim

WORKDIR /app

# Copy only what we need for tool execution
COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY src /app/src

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

# Runner is invoked by `python -m src.runtime.docker_tool_runner`

